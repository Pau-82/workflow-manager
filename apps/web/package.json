{
  "name": "@org/web",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "tags": ["type:app", "scope:web"],
    "targets": {
      "build": {
        "dependsOn": ["^typecheck"],
        "options": { "command": "next build --webpack" }
      },
      "dev": {
        "dependsOn": ["^typecheck"],
        "options": { "command": "next dev --webpack" }
      }
    }
  },
  "dependencies": {
    "@org/api": "workspace:*",
    "@org/contracts": "workspace:*",
    "@tanstack/react-query": "^5.62.0",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "next": "~16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.1.0"
  }
}
